# ──────────────────────────────────────────
# Bakaloo Customer Web — Environment Variables
# Copy this to .env.local and fill in values
# ──────────────────────────────────────────

# Backend API
NEXT_PUBLIC_API_URL=https://api.bakaloo.in

# Socket.IO
NEXT_PUBLIC_SOCKET_URL=https://api.bakaloo.in

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# App
NEXT_PUBLIC_APP_NAME=Bakaloo
NEXT_PUBLIC_ENV=production
